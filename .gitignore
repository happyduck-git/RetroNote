# Playwright E2E 산출물(test:e2e) — 리포트/트레이스/스크린샷, 다운로드된 브라우저
test-results/
playwright-report/
blob-report/
.playwright/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code session data
.claude/

# Local chat secrets (copy config.local.example.js -> config.local.js)
src/config.local.js

# Pet sprites — ToffeeCraft Cat Pochi (paid asset). License forbids redistributing
# the raw art, so the PNGs stay out of this public repo. Generate them locally with
# `npm run slice:pets` (needs the CatMegaBundle source); release CI injects them at build time.
src/assets/pet/**/*.png

# Cat toy assets (공/밥 — CatMegaBundle 유료 에셋). 펫 스프라이트와 같은 라이선스라
# 공개 레포에 두지 않는다. 로컬은 CatMegaBundle 에서 복사, 릴리스 CI 가 사설 레포에서 주입.
src/assets/toys/*

# Supabase CLI link state (local cache: project-ref, version metadata)
supabase/.temp/
supabase/.branches/

# Updater local e2e (scripts/updater-e2e.ps1): serve dir + signing keys — never commit
.updater-e2e/
retronote.key
retronote.key.pub
