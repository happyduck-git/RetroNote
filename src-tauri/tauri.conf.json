{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "retro-note",
  "version": "0.1.4",
  "identifier": "com.retronote.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "retro-note",
        "width": 800,
        "height": 720,
        "minWidth": 400,
        "minHeight": 360,
        "maxWidth": 1400,
        "maxHeight": 1260,
        "decorations": false,
        "transparent": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
